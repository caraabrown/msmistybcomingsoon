{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/document/**",
              "ui_kits/cover-letter/**",
              "ui_kits/resume/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "JSXOpeningElement[name.name='ExpertiseCategory'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|items|key|ref|className|style|children)$/]",
        "message": "<ExpertiseCategory> doesn't accept that prop. Declared props: label, items."
      },
      {
        "selector": "JSXOpeningElement[name.name='HBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:margin|style|key|ref|className|style|children)$/]",
        "message": "<HBar> doesn't accept that prop. Declared props: margin, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='JobBlock'] > JSXAttribute > JSXIdentifier[name!=/^(?:org|date|title|bullets|style|key|ref|className|style|children)$/]",
        "message": "<JobBlock> doesn't accept that prop. Declared props: org, date, title, bullets, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MatchTable'] > JSXAttribute > JSXIdentifier[name!=/^(?:headers|rows|leftWidth|style|key|ref|className|style|children)$/]",
        "message": "<MatchTable> doesn't accept that prop. Declared props: headers, rows, leftWidth, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PrintBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|buttonText|onPrint|style|key|ref|className|style|children)$/]",
        "message": "<PrintBar> doesn't accept that prop. Declared props: label, buttonText, onPrint, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ResumeFooter'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|page|total|portfolio|style|key|ref|className|style|children)$/]",
        "message": "<ResumeFooter> doesn't accept that prop. Declared props: name, page, total, portfolio, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ResumeHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|suffix|titles|contact|hbar|hbarMargin|key|ref|className|style|children)$/]",
        "message": "<ResumeHeader> doesn't accept that prop. Declared props: name, suffix, titles, contact, hbar, hbarMargin."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionLabel'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|style|key|ref|className|style|children)$/]",
        "message": "<SectionLabel> doesn't accept that prop. Declared props: children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Synopsis'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|style|key|ref|className|style|children)$/]",
        "message": "<Synopsis> doesn't accept that prop. Declared props: children, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "ExpertiseCategory": {
        "replaces": []
      },
      "HBar": {
        "replaces": []
